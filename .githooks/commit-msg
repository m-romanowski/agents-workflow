#!/bin/sh

set -eu

message_file=$1
subject_line=$(sed -n '1p' "$message_file")

pattern='^(feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert)(\([A-Za-z0-9._/-]+\))?!?: .+'

if printf '%s\n' "$subject_line" | grep -Eq "$pattern"; then
  exit 0
fi

echo "Commit message must follow Conventional Commits." >&2
echo "Example: feat(workflow): add validator pre-commit hook" >&2
echo "Allowed types: feat, fix, docs, style, refactor, test, chore, build, ci, perf, revert" >&2
exit 1
